# Electron Builder 配置
# ⚠️ 不要在此处设置 electron_mirror / electron_builder_binaries_mirror
# 国内镜像配置请使用 .npmrc.local（本地开发专用），CI 需要访问官方源以获取最新二进制（如 dmg-builder）

# 原生模块配置 - 优先使用预编译二进制
sharp_binary_host=https://npmmirror.com/mirrors/sharp/
sharp_libvips_binary_host=https://npmmirror.com/mirrors/sharp-libvips/

# 强制使用预编译二进制，避免从源码构建
build_from_source=false

# better-sqlite3 特定配置 - 支持从源码构建
# better-sqlite3 会自动处理跨平台编译，无需特殊镜像配置

# 跳过可选依赖的原生构建
node_gyp_force_process_config=0
