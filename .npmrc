# Electron Builder Configuration
# ⚠️ Do NOT set electron_mirror / electron_builder_binaries_mirror here
# For domestic mirror config, use .npmrc.local (local dev only). CI needs official sources for latest binaries (e.g. dmg-builder)

# Native module configuration - prefer prebuilt binaries
sharp_binary_host=https://npmmirror.com/mirrors/sharp/
sharp_libvips_binary_host=https://npmmirror.com/mirrors/sharp-libvips/

# Force prebuilt binaries, avoid building from source
build_from_source=false

# better-sqlite3 specific configuration - supports building from source
# better-sqlite3 handles cross-platform compilation automatically, no special mirror config needed

# Skip native builds for optional dependencies
node_gyp_force_process_config=0

# ----------------------------------------------------------------------------
# Brand selection
#
# Exposed to scripts as the env var `npm_config_brand` (read by
# scripts/brand-config.js → webpack DefinePlugin → bundled main/renderer).
#
# Override per-invocation with either:
#   npm run build --brand=openkosmos
#   BRAND=openkosmos npm run build      (or `$env:BRAND="openkosmos"` in pwsh)
# ----------------------------------------------------------------------------
brand=investment-studio