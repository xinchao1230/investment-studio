# Environment Configuration
# Controls application behavior and logging:production|development
NODE_ENV=development

# Prompt History Configuration
# Maximum number of prompts to keep in history queue
HISTORY_PROMPT_QUEUE_SIZE=20

# CDN Configuration
# Development Environment CDN Base URL
DEVELOPMENT_BASE_CDN_URL=https://cdn.kosmos-ai.com/dev

# Production Environment CDN Base URL
PRODUCTION_BASE_CDN_URL=https://cdn.kosmos-ai.com

# Remote Channel Relay Service URLs (optional)
# If unset, the app falls back to the built-in defaults for development and production.
# DEVELOPMENT_RELAY_SERVICE_URL=
# PRODUCTION_RELAY_SERVICE_URL=

# Active User Tracking
# Active user detection threshold (unit: minutes), default 5 minutes
# Users who continue using the app beyond this duration after launch are recorded as “active users”
# During development/testing, set a smaller value for quick verification, e.g. 0.5 means 30 seconds
ACTIVE_USER_THRESHOLD_MIN=5